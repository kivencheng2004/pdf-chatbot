  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.0.3",
